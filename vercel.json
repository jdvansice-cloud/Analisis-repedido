{
  "version": 2,
  "builds": [
    {
      "src": "api/upload.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/upload.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
